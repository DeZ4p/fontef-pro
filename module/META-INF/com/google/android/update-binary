#!/sbin/sh

TMPDIR=/dev/tmp
MOUNTPATH=/dev/magisk_merge

if [ ! -d $TMPDIR ]; then
  mkdir -p $TMPDIR
fi

setup_flashable() {
  OUTFD=$2
  ZIPFILE=$3
  if [ -z "$OUTFD" ] || readlink /proc/$$/fd/$OUTFD 2>/dev/null | grep -q /tmp; then
    for FD in $(ls /proc/$$/fd); do
      if readlink /proc/$$/fd/$FD 2>/dev/null | grep -q pipe; then
        if ps | grep -v grep | grep -q " 3 $FD "; then
          OUTFD=$FD
          break
        fi
      fi
    done
  fi
}

ui_print() {
  echo -e "ui_print $1\nui_print" >> /proc/self/fd/$OUTFD
}

setup_flashable "$@"

MODPATH=/data/adb/modules/FontEF_Pro

ui_print ""
ui_print "================================"
ui_print "  FontEF Pro v1.0"
ui_print "  by @DeZ4p"
ui_print "================================"
ui_print ""

mkdir -p $MODPATH

unzip -o "$ZIPFILE" -d $MODPATH -x 'META-INF/*' >&2

if [ -f $MODPATH/customize.sh ]; then
  . $MODPATH/customize.sh
fi

ui_print ""
ui_print "[OK] Installation complete!"
ui_print "[*] Please reboot your device"
ui_print ""

exit 0
